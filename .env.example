# Postgres (Neon)
DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"

# Telegram bot
TELEGRAM_BOT_TOKEN=""

# JWT secret for magic-link auth (gerar com: openssl rand -base64 32)
AUTH_JWT_SECRET=""

# AES-256-GCM master key, base64, 32 bytes (gerar com: openssl rand -base64 32)
# Usado para envelopar as API keys BYOK dos usuários.
ENCRYPTION_MASTER_KEY=""

# URL pública do dashboard (usada no link mágico)
DASHBOARD_URL="http://localhost:3000"

# Fallback opcional (dev only) — em produção a chave vem da tabela `ApiKey`
# (BYOK do usuário, AES-256-GCM com ENCRYPTION_MASTER_KEY).
# Se vazia, o bot exige BYOK e responde com instrução pra /dashboard.
# Aceita sk-ant-… (Anthropic) ou sk-…/org-… (OpenAI). Provider é detectado.
LLM_API_KEY=""

# Bot delivery mode:
#   - "polling" para dev local
#   - "webhook" para Railway/produção
BOT_MODE="polling"

# Webhook (apenas quando BOT_MODE=webhook)
BOT_WEBHOOK_URL=""
BOT_WEBHOOK_SECRET=""
PORT="8080"
