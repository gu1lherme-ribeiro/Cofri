generator client {
  provider      = "prisma-client-js"
  // `rhel-openssl-3.0.x` é o runtime AWS Lambda da Vercel; `native`
  // mantém o engine local pra dev. Sem isso, o build do Vercel
  // gera só o engine local e o function explode em runtime.
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         String   @id @default(cuid())
  telegramId BigInt   @unique
  email      String?  @unique
  createdAt  DateTime @default(now())

  apiKeys        ApiKey[]
  transactions   Transaction[]
  reminders      Reminder[]
  budgets        Budget[]
  budgetAlerts   BudgetAlert[]
  fixedExpenses  FixedExpense[]
}

model ApiKey {
  id         String   @id @default(cuid())
  userId     String
  provider   String   // "anthropic" | "openai" | "gemini"
  ciphertext Bytes
  iv         Bytes
  authTag    Bytes
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
}

model Transaction {
  id          String   @id @default(cuid())
  userId      String
  amount      Decimal  @db.Decimal(12, 2)
  kind        String   // "expense" | "income"
  category    String
  description String
  occurredAt  DateTime
  rawMessage  String
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, occurredAt])
}

model Reminder {
  id         String    @id @default(cuid())
  userId     String
  text       String
  dueAt      DateTime
  notifiedAt DateTime?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, dueAt])
}

model Budget {
  id            String   @id @default(cuid())
  userId        String
  category      String
  monthlyAmount Decimal  @db.Decimal(12, 2)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, category])
}

model BudgetAlert {
  id        String   @id @default(cuid())
  userId    String
  category  String
  period    String   // "YYYY-MM" pra escopo mensal
  threshold Int      // 80 ou 100
  sentAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, category, period, threshold])
}

model FixedExpense {
  id        String   @id @default(cuid())
  userId    String
  name      String                   // ex: "Faculdade", "Aluguel"
  amount    Decimal  @db.Decimal(12, 2)
  dueDay    Int                      // 1-31 (dia do mês)
  category  String                   // mesma taxonomia do Transaction
  leadDays  Int[]                    // dias antes do vencimento p/ avisar (1-7); default [1, 2]
  active    Boolean  @default(true)
  // Parcelamento / prazo finito. Quando installmentsTotal é null, a conta é
  // recorrente sem fim. Quando preenchido, installmentsStartMonth marca o
  // mês ("YYYY-MM") da 1ª parcela; a última parcela cai em
  // start + (total - 1) meses, no mesmo dueDay. Ao passar do último
  // vencimento, o bot envia parabéns e seta completedAt.
  installmentsTotal      Int?
  installmentsStartMonth String?
  completedAt            DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user          User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  notifications FixedExpenseNotification[]

  @@index([userId, active])
}

model FixedExpenseNotification {
  id             String   @id @default(cuid())
  fixedExpenseId String
  period         String   // "YYYY-MM" do mês de vencimento que disparou o aviso
  leadDay        Int      // qual lead day disparou (1, 2, ...)
  sentAt         DateTime @default(now())

  fixedExpense FixedExpense @relation(fields: [fixedExpenseId], references: [id], onDelete: Cascade)

  @@unique([fixedExpenseId, period, leadDay])
}
